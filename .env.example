# Copy this file to .env and fill in your real values.
# cp .env.example .env

# Certificate generation/output
PRIVATE_KEY_FILE=cert/rev_privatecert.pem
PUBLIC_CERT_FILE=cert/rev_publiccert.cer
COMMON_NAME=revolut-client
CERT_DAYS=1825
CERT_COUNTRY=SI
CERT_STATE=Slovenia
CERT_LOCALITY=Maribor
CERT_ORGANIZATION="Your Company d.o.o."
CERT_ORG_UNIT=IT
CERT_EMAIL=name@example.com
# Leave empty to be prompted interactively by openssl.
# Quote if it contains shell-special chars (space, |, &, $, etc.).
CERT_PASSWORD=
PFX_FILE=cert/rev-cert.pfx
BASE64_FILE=cert/rev-certpfx.base64

# JWT client assertion (generated by 1_create_jwt.sh)
JWT_KEY_FILE=cert/rev_privatecert.pem
JWT_ALG=RS256
JWT_TYP=JWT
# Use only the bare domain (no https:// and no path).
JWT_ISS=your-domain.example
# Client ID from Revolut Business app API settings.
JWT_SUB=your_revolut_client_id
JWT_AUD=https://revolut.com
# Preferred: set number of days from now (e.g. 5). Script computes JWT_EXP automatically.
JWT_EXP_DAYS=5
# Auto-updated by 1_create_jwt.sh
JWT_TOKEN_CLIENT_ASSERTION=

# OAuth environment/endpoints (used by 2_get_code.sh and 3_get_api_token.sh)
# Allowed values: production, sandbox
REVOLUT_ENV=sandbox
AUTHORIZE_URL_PRODUCTION=https://business.revolut.com/app-confirm
AUTHORIZE_URL_SANDBOX=https://sandbox-business.revolut.com/app-confirm
TOKEN_URL_PRODUCTION=https://b2b.revolut.com/api/1.0/auth/token
TOKEN_URL_SANDBOX=https://sandbox-b2b.revolut.com/api/1.0/auth/token
# Auto-updated by 2_get_code.sh
AUTH_CODE=
